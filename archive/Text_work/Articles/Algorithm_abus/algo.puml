@startuml

:Обращение пациента;
:Подписание согласия;


if  (Возраст пациентки) then (40 лет и старше)
group <b>40 лет и старше</b>
:Сбор анамнеза;
:Выполнение диагностической маммографии;
    if  (Факторы:
    края образования на ММГ: нечеткие
    первичный диагноз: Локализованный фиброаденоматоз
    жалоба на уплотнение
    характеристика узла на ММГ: фокус уплотнения
    фон на ММГ: железистая ткань
    наследственная предрасположенность
    репродуктивный статус: менопауза более 5 лет
    гормональная терапия
    возраст пациента

) then (да)
#PeachPuff:направить на 2D УЗИ\n Причина: высокий риск необходимости\n проведения биопсии;
    else (нет)
    #palegreen:направить на 3D УЗИ;
    endif
end group
else (менее 40 лет)
group <b>менее 40 лет</b>
:Сбор анамнеза;
    if  (Факторы:
    наследственная предрасположенность
    первичный диагноз: диффузный фиброаденоматоз
    репродуктивный статус: пременопауза
    жалоба на уплотнение
    возраст пациента
) then (да)
#PeachPuff:направить на 2D УЗИ\n Причина: высокий риск необходимости\n проведения биопсии;
    else (нет)
    #palegreen: направить на 3D УЗИ;
    endif
end group
endif
if (BiRads 1 и 2 \nпо результату 2D УЗИ) then (да)
#palegreen:Дальнейшее наблюдение;
stop
else(нет)
if  (BiRads 3 \nпо результату 2D УЗИ) then (да)
#PeachPuff:Наблюдение 3-6 мес \n затем/bли МРТ с КУ;
    if (BiRads 1 и 2 \nпо результату МРТ) then (да)
    #palegreen:Дальнейшее наблюдение;
    stop
    else(нет)
    #salmon:Core биопсия/\nПункционная биопсия;
    stop
    endif

else(нет)
:BiRads 4 и BiRads 5; 
#salmon:Core биопсия/\nПункционная биопсия;
stop

@endumll
